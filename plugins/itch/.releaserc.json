{
  "extends": "semantic-release-monorepo",
  "branches": ["main"],
  "tagFormat": "itch-v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    ["@semantic-release/exec", {
      "prepareCmd": "cargo build --release --target wasm32-unknown-unknown -p itch-plugin && jq '.version = \"${nextRelease.version}\"' manifest.json > manifest.tmp && mv manifest.tmp manifest.json"
    }],
    ["@semantic-release/github", {
      "assets": [
        {"path": "../../target/wasm32-unknown-unknown/release/itch_plugin.wasm", "name": "itch.wasm", "label": "itch.io Plugin WASM"},
        {"path": "manifest.json", "name": "manifest.json", "label": "Plugin Manifest"}
      ]
    }]
  ]
}
