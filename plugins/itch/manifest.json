    {
      "key": "PLUGIN_ITCH_CLIENT_SECRET",
      "name": "OAuth Client Secret",
      "description": "From your itch.io OAuth application"
    }
  ],
  "description": "Import your itch.io game library and purchases.",
  "wasm_file": "itch.wasm"
}
