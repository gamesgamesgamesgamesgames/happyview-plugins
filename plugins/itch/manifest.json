{
  "id": "itch",
  "name": "itch.io",
  "version": "0.1.0",
  "api_version": "1",
  "icon_url": "https://itch.io/favicon.ico",
  "auth_type": "oauth2",
  "required_secrets": [
    {
      "key": "PLUGIN_ITCH_CLIENT_ID",
      "name": "OAuth Client ID",
